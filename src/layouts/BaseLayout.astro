---
import '@/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import PaperTexture from '@/components/effects/PaperTexture.astro';
import ScrollProgress from '@/components/effects/ScrollProgress.tsx';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  lang?: string;
}

const {
  title,
  description = '',
  ogImage,
  lang = 'ko',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
// Default OG image — 한지 톤 1200×630 PNG (generated from og-image.svg via sharp).
const resolvedOgImage = new URL(ogImage ?? '/og-image.png', Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#FAF6EC" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalURL.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />

    <ClientRouter />
  </head>
  <body class="bg-paper-base text-ink-body antialiased min-h-screen flex flex-col overflow-x-hidden">
    <PaperTexture />
    <ScrollProgress client:load />
    <Header />
    <main id="main" class="relative z-[2] flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
