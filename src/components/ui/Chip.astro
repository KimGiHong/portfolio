---
/**
 * Chip
 * Small mono-typeset pill for tech stack tags and metadata.
 */

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center px-2 py-0.5 rounded-full bg-paper-fiber/50 border border-border-soft text-[11px] font-mono text-ink-muted',
    className,
  ]}
>
  <slot />
</span>
