---
/**
 * Footer
 * Quiet site footer with mixed-script colophon line and three icon links.
 * Wrapped icons use InkLink so they share the ink-bleed underline language.
 */
import InkLink from '@/components/effects/InkLink.astro';
import { profile } from '@/content/profile';

const year = new Date().getFullYear();

const socials: {
  label: string;
  href: string;
  external: boolean;
  icon: 'github' | 'linkedin' | 'mail';
}[] = [
  { label: 'LinkedIn', href: profile.socials.linkedin, external: true, icon: 'linkedin' },
  { label: 'GitHub', href: profile.socials.github, external: true, icon: 'github' },
  { label: 'Email', href: profile.socials.email, external: false, icon: 'mail' },
];
---

<footer
  class="relative z-[2] mt-24 border-t border-border-soft py-16 text-ink-muted print:hidden"
>
  <div
    class="mx-auto max-w-[68rem] px-6 sm:px-8 lg:px-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6"
  >
    <p class="text-sm leading-relaxed">
      <span class="font-mono text-ink-subtle mr-1">©</span>
      <span class="font-display italic">{year}</span>
      <span class="font-display-ko mx-1">{profile.name.ko}</span>
      <span class="font-display italic">({profile.name.en}).</span>
    </p>

    <ul class="flex items-center gap-5">
      {
        socials.map((social) => (
          <li>
            <InkLink
              href={social.href}
              external={social.external}
              class="inline-flex items-center gap-2 !text-ink-muted hover:!text-accent-maple transition-colors"
            >
              <span class="sr-only">{social.label}</span>
              <span aria-hidden="true" class="inline-flex">
                {social.icon === 'github' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 1.5a6.5 6.5 0 0 0-2.05 12.66c.32.06.44-.14.44-.31v-1.2c-1.81.39-2.19-.77-2.19-.77-.3-.75-.72-.95-.72-.95-.59-.4.05-.4.05-.4.65.05.99.67.99.67.58 1 1.52.71 1.89.54.06-.42.23-.71.41-.87-1.45-.16-2.97-.72-2.97-3.2 0-.71.26-1.29.67-1.74-.07-.16-.29-.82.07-1.71 0 0 .55-.18 1.8.67a6.3 6.3 0 0 1 3.27 0c1.24-.85 1.79-.67 1.79-.67.36.89.14 1.55.07 1.71.42.45.67 1.03.67 1.74 0 2.48-1.52 3.04-2.97 3.2.23.2.44.6.44 1.2v1.78c0 .17.12.38.45.31A6.5 6.5 0 0 0 8 1.5Z" />
                  </svg>
                )}
                {social.icon === 'linkedin' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="12" height="12" rx="1.2" />
                    <path d="M5 7v4.5" />
                    <circle cx="5" cy="5" r="0.4" fill="currentColor" />
                    <path d="M8 11.5V7M8 8.6c.4-1 1.2-1.6 2.2-1.6 1.1 0 1.8.7 1.8 2v3.1" />
                  </svg>
                )}
                {social.icon === 'mail' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3.5" width="12" height="9" rx="1.2" />
                    <path d="m2.5 4.5 5.5 4 5.5-4" />
                  </svg>
                )}
              </span>
              <span class="text-[12px] font-mono tracking-wide uppercase">{social.label}</span>
            </InkLink>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
