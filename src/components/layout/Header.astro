---
/**
 * Header
 * Sticky paper-tinted nav with backdrop blur. Border-bottom appears only
 * after the page scrolls past the brand baseline (data-scrolled attribute
 * toggled by a tiny inline script). Mobile uses a CSS-only <details>
 * disclosure for the link list.
 */

const pathname = Astro.url.pathname;

const links: { href: string; label: string }[] = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/resume', label: 'Resume' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-paper-base/70 backdrop-blur-md transition-[border-color,background-color] duration-300 border-b border-transparent data-[scrolled=true]:border-border-soft data-[scrolled=true]:bg-paper-base/85 print:hidden"
>
  <div class="mx-auto max-w-[68rem] px-6 sm:px-8 lg:px-10">
    <div class="flex items-center justify-between gap-6 h-16 sm:h-20">
      <a
        href="/"
        class="group inline-flex items-baseline gap-2 text-ink-primary"
        aria-label="KimGiHong · 김기홍 — Home"
      >
        <span class="font-display italic text-xl sm:text-2xl leading-none">KimGiHong</span>
        <span
          class="font-display-ko text-[13px] sm:text-sm text-ink-muted leading-none tracking-tight transition-colors group-hover:text-accent-maple"
        >
          김기홍
        </span>
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary" class="hidden sm:block">
        <ul class="flex items-center gap-7 text-[14px]">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                  class:list={[
                    'relative inline-block py-1 transition-colors duration-200',
                    isActive(link.href)
                      ? 'text-ink-primary'
                      : 'text-ink-muted hover:text-ink-primary',
                  ]}
                >
                  {link.label}
                  {isActive(link.href) && (
                    <span
                      aria-hidden="true"
                      class="absolute left-0 right-0 -bottom-0.5 h-px bg-accent-maple"
                    />
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Mobile disclosure -->
      <details class="sm:hidden mobile-nav relative">
        <summary
          class="list-none inline-flex items-center justify-center w-10 h-10 -mr-2 cursor-pointer text-ink-primary"
          aria-label="Toggle navigation"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path d="M3 6h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
            <path d="M3 10h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
            <path d="M3 14h14" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" />
          </svg>
        </summary>
        <nav
          aria-label="Primary mobile"
          class="absolute right-0 top-full mt-2 min-w-[10rem] rounded border border-border-soft bg-paper-base/95 backdrop-blur-md shadow-sm py-2"
        >
          <ul class="flex flex-col">
            {
              links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-current={isActive(link.href) ? 'page' : undefined}
                    class:list={[
                      'block px-4 py-2 text-[14px] transition-colors',
                      isActive(link.href)
                        ? 'text-ink-primary'
                        : 'text-ink-muted hover:text-ink-primary',
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  /* Hide default disclosure marker across browsers. */
  .mobile-nav > summary {
    list-style: none;
  }
  .mobile-nav > summary::-webkit-details-marker {
    display: none;
  }
</style>

<script>
  const setup = () => {
    const header = document.getElementById('site-header');
    if (!header) return;
    const onScroll = () => {
      header.dataset.scrolled = window.scrollY > 4 ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  };
  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
