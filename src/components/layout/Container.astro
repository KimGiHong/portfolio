---
/**
 * Container
 * Centered max-width wrapper. Three measure-based sizes for prose vs. layout.
 */

type Size = 'narrow' | 'default' | 'wide';

interface Props {
  size?: Size;
  class?: string;
}

const { size = 'default', class: className = '' } = Astro.props;

const sizeClass: Record<Size, string> = {
  narrow: 'max-w-[58ch]',
  default: 'max-w-[72ch]',
  wide: 'max-w-[68rem]',
};
---

<div class:list={['mx-auto px-6 sm:px-8 lg:px-10', sizeClass[size], className]}>
  <slot />
</div>
