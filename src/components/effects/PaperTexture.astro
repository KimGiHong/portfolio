---
/**
 * PaperTexture
 * Fixed full-viewport overlay that simulates 한지 fiber/grain via SVG
 * fractal noise. Rendered once at the layout level. Pointer-transparent
 * and hidden in print.
 */
---

<div class="paper-texture" aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="100%"
    height="100%"
    preserveAspectRatio="xMidYMid slice"
  >
    <filter id="hanji-grain" x="0" y="0" width="100%" height="100%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.9"
        numOctaves="2"
        seed="7"
        stitchTiles="stitch"
      />
      <feColorMatrix
        type="matrix"
        values="0 0 0 0 0.32
                0 0 0 0 0.28
                0 0 0 0 0.20
                0 0 0 0.55 0"
      />
    </filter>
    <rect width="100%" height="100%" filter="url(#hanji-grain)" />
  </svg>
</div>

<style>
  .paper-texture {
    position: fixed;
    inset: 0;
    pointer-events: none;
    mix-blend-mode: multiply;
    opacity: 0.05;
    z-index: 1;
    user-select: none;
  }

  .paper-texture svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  @media print {
    .paper-texture {
      display: none;
    }
  }
</style>
